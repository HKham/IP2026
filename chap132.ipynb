    "import cv2\n",
    "import numpy as np\n",
    "\n",
    "img1 = cv2.imread('set1.jpg')\n",
    "img2 = cv2.imread('set2.jpg')\n",
    "\n",
    "dst = cv2.addWeighted(img1,0.4,img2,0.6,0)\n",
    "\n",
    "cv2.imshow('dst',dst)\n",
    "cv2.waitKey(0)\n",
    "cv2.destroyAllWindows()\n"
   ]
